{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "maxLength": 255,
      "minLength": 5
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "maxLength": 255
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "sections.navbar",
        "sections.hero-home",
        "sections.footer",
        "sections.partners",
        "sections.company-intro",
        "sections.hero",
        "sections.vision-mission",
        "sections.image",
        "sections.sitemap",
        "sections.information-support",
        "sections.rich-text-section",
        "sections.quote",
        "sections.about-us",
        "sections.contact-us",
        "sections.raw-html",
        "sections.whistleblowing",
        "sections.text-headline",
        "sections.image-with-content",
        "sections.lottie",
        "sections.subheadline",
        "sections.multiple-download-item",
        "sections.hero-anchor",
        "sections.grouped-download-item"
      ],
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.seo"
    }
  }
}

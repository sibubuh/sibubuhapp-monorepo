{
  "collectionName": "components_sections_csr_overviews",
  "info": {
    "displayName": "CsrOverview",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "description": {
      "type": "text",
      "required": true,
      "maxLength": 1000
    },
    "link": {
      "type": "component",
      "repeatable": false,
      "required": true,
      "component": "repeatable.anchor"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "background_color": {
      "type": "customField",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
      "required": true,
      "customField": "plugin::color-picker.color"
    }
  }
}

{
	"name": "frontend",
	"description": "TanStack Start application",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node .output/server/index.mjs",
		"cleanup": "pnpm dlx del-cli node_modules .output .vinxi dist tests-results",
		"update-deps": "npm-check-updates --configFileName .ncurc.json",
		"test-report": "pnpm dlx serve tests-results -l 9000 -s -n -C",
		"test-coverage": "pnpm run typegen && vitest run --coverage",
		"test-ui": "pnpm run typegen && vitest --ui",
		"test": "pnpm run typegen && vitest --run",
		"lint": "biome lint . --write",
		"check": "biome check . --write",
		"e2e-install": "playwright install --with-deps",
		"e2e-chrome": "playwright test --headed --project Chromium",
		"e2e-firefox": "playwright test --headed --project Firefox",
		"e2e-mobile": "playwright test --headed --project 'Mobile Chrome'",
		"e2e-safari": "playwright test --headed --project Safari",
		"e2e-report": "playwright show-report tests-results/e2e-html",
		"e2e-ui": "playwright test --ui",
		"e2e": "playwright test",
		"typegen": "tsr generate",
		"typecheck": "pnpm run typegen && tsc --noEmit"
	},
	"dependencies": {
		"@tanstack/react-router": "1.158.4",
		"@tanstack/react-router-devtools": "1.158.4",
		"@tanstack/react-start": "1.159.0",
		"@tanstack/start": "^1.120.20",
		"consola": "^3.4.2",
		"framer-motion": "^12.38.0",
		"googleapis": "^171.4.0",
		"lottie-react": "^2.4.1",
		"lucide-react": "^0.563.0",
		"motion": "^12.38.0",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"std-env": "^3.10.0",
		"tailwind-variants": "^3.2.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/router-cli": "1.158.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^14.2.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20.11.30",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^5.0.0",
		"@vitest/coverage-v8": "^1.5.0",
		"@vitest/ui": "^1.5.0",
		"dotenv": "^17.2.4",
		"happy-dom": "^14.12.3",
		"npm-check-updates": "^16.14.12",
		"playwright": "^1.58.2",
		"tailwindcss": "^4.1.18",
		"tailwindcss-motion": "^1.1.1",
		"typescript": "5.3.3",
		"vinxi": "^0.5.3",
		"vite": "^7.0.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-tsconfig-paths": "^4.3.2",
		"vitest": "^1.5.0"
	}
}
